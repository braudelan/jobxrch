ANTHROPIC_API_KEY=

# Optional: web search in chat
TAVILY_API_KEY=

# Optional: set LLM_PROVIDER=gemini to use Gemini instead
GEMINI_API_KEY=

# Optional: select LLM provider (anthropic|gemini|ollama), defaults to anthropic
LLM_PROVIDER=anthropic

# Ollama (local) — used when LLM_PROVIDER=ollama
# Requires Ollama running locally: https://ollama.com
# Recommended model (tool-calling support): ollama pull qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
